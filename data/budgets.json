import json
from openpyxl import load_workbook

WORKBOOK_PATH = "Budget2026.xlsx"
HISTORY_JSON_PATH = "history.json"
OUTPUT_PATH = "budgets.json"

REVENUE_ROW = 74
OCCUPANCY_ROW = 460
FIRST_BUDGET_COL = 41  # Jan26B — confirmed
NUM_BUDGET_MONTHS = 12

TAB_TO_SITE_KEY = {
    "Eindhoven-Best": "NL-01-Eindhoven-Best",
    "Den Bosch": "NL-02-Den Bosch",
    "Nijmegen-Wijchen": "NL-03-Nijmegen-Wijchen",
    "Boxtel": "NL-04-Boxtel",
    "Rijswijk": "NL-05-Rijswijk",
    "Groningen": "NL-06-Groningen",
    "Venlo": "NL-07-Venlo",
    "Roermond": "NL-08-Roermond",
    "Sittard": "NL-09-Sittard",
    "Heerlen": "NL-10-Heerlen",
    "Bergen op Zoom": "NL-11-Bergen op Zoom",
    "Goes": "NL-12-Goes",
    "Hellevoetsluis": "NL-13-Hellevoetsluis",
    "Tilburg": "NL-14-Tilburg",
    "Breda": "NL-15-Breda",
    "Den Haag": "NL-16-Den Haag",
    "Utrecht": "NL-17-Utrecht",
    "Barendrecht": "NL-18-Barendrecht",
    "Helmond": "NL-20-Helmond",
    "Heerlen-Heerlerbaan": "NL-21-Heerlen-Heerlerbaan",
    "Rotterdam Centrum": "NL-22-Rotterdam Centrum",
    "Schiedam": "NL-23-Schiedam",
    "Rotterdam Zuid": "NL-24-Rotterdam Zuid",
    "Alphen aan den Rijn": "NL-25-Alphen aan den Rijn",
    "Alkmaar": "NL-26-Alkmaar",
    "Amsterdam": "NL-27-Amsterdam",
    "Almere": "NL-28-Almere",
    "Helmond-Kanaaldijk": "NL-29-Helmond-Kanaaldijk",
    "Lelystad": "NL-30-Lelystad",
}

# ─── don't edit below ───

wb = load_workbook(WORKBOOK_PATH, data_only=True, read_only=True)
with open(HISTORY_JSON_PATH) as f:
    history = json.load(f)
known_keys = set(history["sites"].keys())

month_keys = [f"2026-{m:02d}" for m in range(1, NUM_BUDGET_MONTHS + 1)]

budgets = {"sites": {}}
processed, skipped = 0, []

for tab_name, site_key in TAB_TO_SITE_KEY.items():
    if tab_name not in wb.sheetnames:
        skipped.append(f"{tab_name} (tab not found)")
        continue
    if site_key not in known_keys:
        skipped.append(f"{tab_name} → {site_key} (key not in history.json)")
        continue

    ws = wb[tab_name]
    site_budgets = {}
    for i, month_key in enumerate(month_keys):
        col = FIRST_BUDGET_COL + i
        rev_cell = ws.cell(row=REVENUE_ROW, column=col).value
        occ_cell = ws.cell(row=OCCUPANCY_ROW, column=col).value

        revenue = round(rev_cell * 1000) if isinstance(rev_cell, (int, float)) else None
        occupancy_pct = None
        if isinstance(occ_cell, (int, float)):
            occupancy_pct = round(occ_cell * 100, 1) if occ_cell < 1 else round(occ_cell, 1)

        site_budgets[month_key] = {
            "revenue": revenue,
            "occupancy_pct": occupancy_pct
        }

    budgets["sites"][site_key] = site_budgets
    processed += 1

    # Print Jan + Dec for sanity
    jan = site_budgets["2026-01"]
    dec = site_budgets["2026-12"]
    print(f"  ✓ {tab_name:30} Jan26: €{jan['revenue']:,} / {jan['occupancy_pct']}%   Dec26: €{dec['revenue']:,} / {dec['occupancy_pct']}%")

print(f"\nProcessed: {processed}")
if skipped:
    print(f"Skipped: {skipped}")

with open(OUTPUT_PATH, "w") as f:
    json.dump(budgets, f, indent=2)
print(f"\n✓ Wrote {OUTPUT_PATH}")

# Trigger download
from google.colab import files
files.download(OUTPUT_PATH)
